{
  "SalesMessaging": {
    "EventsExchange": "devstore.sales.events.v1",
    "DeadLetterExchange": "devstore.sales.dlx.v1",
    "DeadLetterQueue": "devstore.sales.dlq.v1",
    "CreatedQueue": "devstore.sales.created.persist.v1",
    "ModifiedQueue": "devstore.sales.modified.persist.v1",
    "CancelledQueue": "devstore.sales.cancelled.persist.v1",
    "DeletedQueue": "devstore.sales.deleted.persist.v1",
    "CreatedRoutingKey": "sale.created.v1",
    "ModifiedRoutingKey": "sale.modified.v1",
    "CancelledRoutingKey": "sale.cancelled.v1",
    "DeletedRoutingKey": "sale.deleted.v1",
    "Retry": {
      "MaxRetries": 3,
      "BackoffSeconds": [ 2, 5, 15 ]
    },
    "Audit": {
      "MaxPayloadLength": 64000
    }
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "API",
        "Uri": "http://localhost:8080/health-ui-target"
      }
    ],
    "EvaluationTimeOnSeconds": 15,
    "MinimumSecondsBetweenFailureNotifications": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "StockAlert": {
    "MailjetApiKey": "",
    "MailjetSecretKey": "",
    "FromEmail": "",
    "FromName": "Ambev Dev Evaluation - Estoque",
    "AdminEmail": "",
    "CheckIntervalMinutes": 60
  },
  "AllowedHosts": "*"
}
